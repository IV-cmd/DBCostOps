{
  "dashboard": {
    "id": null,
    "title": "DBCOSTOPS - Cost Overview",
    "tags": ["dbcostops", "cost", "overview"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Total Monthly Cost",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(dbcostops_total_cost[30d]))",
            "legendFormat": "Total Cost"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 500},
                {"color": "red", "value": 1000}
              ]
            },
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Cost Breakdown",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (metric_name) (increase(dbcostops_cost_impact[30d]))",
            "legendFormat": "{{metric_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": {"mode": "palette-classic"}
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Daily Cost Trend",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(increase(dbcostops_total_cost[1d]))",
            "legendFormat": "Daily Cost"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": {"mode": "palette-classic"}
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Cost by Database Type",
        "type": "bargauge",
        "targets": [
          {
            "expr": "sum by (database_type) (increase(dbcostops_cost_impact[30d]))",
            "legendFormat": "{{database_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": {"mode": "palette-classic"}
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 5,
        "title": "Cost Optimization Potential",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(dbcostops_optimization_potential_savings)",
            "legendFormat": "Potential Savings"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {"mode": "thresholds"}
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      }
    ],
    "time": {"from": "now-30d", "to": "now"},
    "refresh": "30s",
    "schemaVersion": 37,
    "version": 1,
    "uid": "dbcostops-cost-overview"
  }
}
